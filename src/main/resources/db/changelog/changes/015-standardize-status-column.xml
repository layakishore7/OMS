<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-rename-record-status-to-status-categories" author="dev">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="categories"/>
                <columnExists tableName="categories" columnName="record_status"/>
                <not>
                    <columnExists tableName="categories" columnName="status"/>
                </not>
            </and>
        </preConditions>
        <renameColumn tableName="categories" oldColumnName="record_status" newColumnName="status" columnDataType="INT"/>
    </changeSet>

